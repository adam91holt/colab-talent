    <script is:inline>
      async function submitInterest(formId, type, successId, errorId) {
        const form = document.getElementById(formId);
        const success = document.getElementById(successId);
        const error = document.getElementById(errorId);

        if (!(form instanceof HTMLFormElement) || !success || !error) return;

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          error.classList.add('hidden');

          const data = Object.fromEntries(new FormData(form));

          try {
            const res = await fetch('https://colab-talent-api.mail-5bc.workers.dev/api/early-interest', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ ...data, type })
            });

            if (res.ok) {
              form.style.display = 'none';
              success.classList.remove('hidden');
            } else {
              error.classList.remove('hidden');
            }
          } catch {
            error.classList.remove('hidden');
          }
        });
      }

      submitInterest('employer-form', 'employer', 'employer-success', 'employer-error');
      submitInterest('candidate-form', 'candidate', 'candidate-success', 'candidate-error');
    </script>

