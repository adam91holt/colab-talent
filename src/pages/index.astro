---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Colab Talent — New Zealand's specialist AI talent placement service. We connect NZ's boldest businesses with world-class AI engineers, data scientists, and ML specialists." />
    <meta property="og:title" content="Colab Talent — Your AI Team. Built Fast." />
    <meta property="og:description" content="We connect New Zealand's boldest businesses with world-class AI engineers, data scientists, and ML specialists." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://talent.thecolab.ai" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>Colab Talent — Your AI Team. Built Fast.</title>
  </head>
  <body class="bg-white antialiased">

    <!-- ==================== HERO ==================== -->
    <section class="relative min-h-screen flex items-center overflow-hidden bg-gradient-to-br from-navy-dark via-navy to-dark">
      <!-- Animated SVG network nodes -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <svg class="absolute right-0 top-0 w-[700px] h-[700px] opacity-20" viewBox="0 0 700 700" fill="none">
          <!-- Nodes -->
          <circle class="node-float-1" cx="350" cy="150" r="6" fill="#0EA5E9" />
          <circle class="node-float-2" cx="500" cy="250" r="4" fill="#0EA5E9" />
          <circle class="node-float-3" cx="250" cy="350" r="5" fill="#0EA5E9" />
          <circle class="node-float-1" cx="450" cy="400" r="7" fill="#38bdf8" />
          <circle class="node-float-2" cx="550" cy="150" r="3" fill="#38bdf8" />
          <circle class="node-float-3" cx="300" cy="500" r="5" fill="#0EA5E9" />
          <circle class="node-float-1" cx="600" cy="350" r="4" fill="#38bdf8" />
          <circle class="node-float-2" cx="400" cy="550" r="6" fill="#0EA5E9" />
          <circle class="node-float-3" cx="150" cy="200" r="3" fill="#38bdf8" />
          <circle class="node-float-1" cx="200" cy="450" r="4" fill="#0EA5E9" />
          <!-- Connecting lines -->
          <line class="node-pulse" x1="350" y1="150" x2="500" y2="250" stroke="#0EA5E9" stroke-width="1" />
          <line class="node-pulse" x1="500" y1="250" x2="450" y2="400" stroke="#0EA5E9" stroke-width="1" />
          <line class="node-pulse" x1="250" y1="350" x2="450" y2="400" stroke="#38bdf8" stroke-width="1" />
          <line class="node-pulse" x1="350" y1="150" x2="550" y2="150" stroke="#38bdf8" stroke-width="0.5" />
          <line class="node-pulse" x1="450" y1="400" x2="600" y2="350" stroke="#0EA5E9" stroke-width="0.5" />
          <line class="node-pulse" x1="300" y1="500" x2="400" y2="550" stroke="#38bdf8" stroke-width="1" />
          <line class="node-pulse" x1="250" y1="350" x2="300" y2="500" stroke="#0EA5E9" stroke-width="0.5" />
          <line class="node-pulse" x1="150" y1="200" x2="250" y2="350" stroke="#38bdf8" stroke-width="0.5" />
          <line class="node-pulse" x1="200" y1="450" x2="300" y2="500" stroke="#0EA5E9" stroke-width="1" />
          <line class="node-pulse" x1="550" y1="150" x2="600" y2="350" stroke="#0EA5E9" stroke-width="0.5" />
          <!-- Larger glow circles -->
          <circle class="node-float-2" cx="350" cy="150" r="20" fill="#0EA5E9" opacity="0.08" />
          <circle class="node-float-1" cx="450" cy="400" r="25" fill="#0EA5E9" opacity="0.06" />
          <circle class="node-float-3" cx="300" cy="500" r="18" fill="#38bdf8" opacity="0.07" />
        </svg>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 py-24 lg:py-32">
        <!-- Logo -->
        <div class="mb-12">
          <span class="text-2xl font-bold tracking-tight">
            <span class="text-white">The</span><span class="text-sky">Colab</span>
          </span>
          <span class="text-gray ml-2 text-sm font-medium uppercase tracking-widest">Talent</span>
        </div>

        <div class="max-w-3xl">
          <h1 class="text-5xl md:text-7xl font-black text-white leading-tight mb-6">
            Your AI Team.<br />
            <span class="text-sky">Built Fast.</span>
          </h1>
          <p class="text-xl md:text-2xl text-gray-300 leading-relaxed mb-10 max-w-2xl">
            We connect New Zealand's boldest businesses with world-class AI engineers, data scientists, and ML specialists.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#employers" class="inline-flex items-center justify-center px-8 py-4 bg-sky text-white font-semibold rounded-lg text-lg hover:bg-sky-light transition-colors duration-200 shadow-lg shadow-sky/25">
              I'm Hiring
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </a>
            <a href="#candidates" class="inline-flex items-center justify-center px-8 py-4 bg-white/10 text-white font-semibold rounded-lg text-lg hover:bg-white/20 transition-colors duration-200 border border-white/20">
              I'm a Candidate
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Bottom gradient fade -->
      <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-dark to-transparent"></div>
    </section>

    <!-- ==================== THE PROBLEM ==================== -->
    <section class="bg-dark py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-6">The Reality</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-16 max-w-2xl">
          New Zealand has an AI talent problem.
        </h2>
        <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
          <div class="border-l-2 border-sky pl-6">
            <p class="text-4xl md:text-5xl font-black text-white mb-3">6+</p>
            <p class="text-lg text-gray-300">months — the average time to find senior AI talent in NZ</p>
          </div>
          <div class="border-l-2 border-sky pl-6">
            <p class="text-4xl md:text-5xl font-black text-white mb-3">87%</p>
            <p class="text-lg text-gray-300">of NZ businesses say AI skills are their #1 hiring challenge</p>
          </div>
          <div class="border-l-2 border-sky pl-6">
            <p class="text-4xl md:text-5xl font-black text-white mb-3">3x</p>
            <p class="text-lg text-gray-300">the annual salary — the cost of a bad AI hire</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== WHAT WE OFFER ==================== -->
    <section class="bg-white py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">What We Offer</p>
          <h2 class="text-3xl md:text-5xl font-bold text-dark">Three ways to build your AI capability</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <!-- Embedded Talent -->
          <div class="group bg-gray-light rounded-2xl p-8 lg:p-10 hover:shadow-xl transition-shadow duration-300">
            <div class="w-14 h-14 bg-sky/10 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-sky" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-3">Embedded Talent</h3>
            <p class="text-gray leading-relaxed">Senior AI engineers and data scientists placed directly in your team, full-time or part-time.</p>
          </div>
          <!-- Project Squads -->
          <div class="group bg-gray-light rounded-2xl p-8 lg:p-10 hover:shadow-xl transition-shadow duration-300">
            <div class="w-14 h-14 bg-sky/10 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-sky" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-3">Project Squads</h3>
            <p class="text-gray leading-relaxed">Pre-assembled teams built for specific AI projects, from discovery through delivery.</p>
          </div>
          <!-- Talent Advisory -->
          <div class="group bg-gray-light rounded-2xl p-8 lg:p-10 hover:shadow-xl transition-shadow duration-300">
            <div class="w-14 h-14 bg-sky/10 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-sky" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-3">Talent Advisory</h3>
            <p class="text-gray leading-relaxed">Role design, market mapping, and hiring strategy to build your internal AI capability.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== HOW IT WORKS ==================== -->
    <section class="bg-gray-light py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">How It Works</p>
          <h2 class="text-3xl md:text-5xl font-bold text-dark">Four steps to your AI team</h2>
        </div>
        <div class="grid md:grid-cols-4 gap-8 lg:gap-6">
          <!-- Step 1 -->
          <div class="relative text-center">
            <div class="w-16 h-16 bg-sky text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">1</div>
            <h3 class="text-lg font-bold text-dark mb-2">Discover</h3>
            <p class="text-gray text-sm leading-relaxed">We learn your goals, culture, and technical needs</p>
          </div>
          <!-- Step 2 -->
          <div class="relative text-center">
            <div class="w-16 h-16 bg-sky text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">2</div>
            <h3 class="text-lg font-bold text-dark mb-2">Match</h3>
            <p class="text-gray text-sm leading-relaxed">Pre-vetted candidates within 48 hours</p>
          </div>
          <!-- Step 3 -->
          <div class="relative text-center">
            <div class="w-16 h-16 bg-sky text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">3</div>
            <h3 class="text-lg font-bold text-dark mb-2">Embed</h3>
            <p class="text-gray text-sm leading-relaxed">Talent integrates fast with your team</p>
          </div>
          <!-- Step 4 -->
          <div class="relative text-center">
            <div class="w-16 h-16 bg-sky text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">4</div>
            <h3 class="text-lg font-bold text-dark mb-2">Grow</h3>
            <p class="text-gray text-sm leading-relaxed">We stay engaged to make sure it works long-term</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== FOR EMPLOYERS ==================== -->
    <section id="employers" class="bg-white py-24 lg:py-32">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-12">
          <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">For Employers</p>
          <h2 class="text-3xl md:text-5xl font-bold text-dark mb-4">Build Your AI Team</h2>
          <p class="text-xl text-gray">Tell us what you need and we'll be in touch within 48 hours.</p>
        </div>
        <div class="bg-gray-light rounded-2xl p-8 lg:p-12">
          {/* =====================================================
               TODO: Replace with real HubSpot Employer Form values
               Portal ID: EMPLOYER_PORTAL_ID
               Form ID:   EMPLOYER_FORM_ID
               ===================================================== */}
          <div id="hubspot-employer-form"></div>
          <noscript><p class="text-center text-gray">Please enable JavaScript to load the contact form, or email us directly.</p></noscript>
        </div>
      </div>
    </section>

    <!-- ==================== FOR CANDIDATES ==================== -->
    <section id="candidates" class="py-24 lg:py-32" style="background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-12">
          <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">For Candidates</p>
          <h2 class="text-3xl md:text-5xl font-bold text-dark mb-4">Join the Colab Talent Network</h2>
          <p class="text-xl text-gray">We place top AI engineers, data scientists and ML specialists with NZ's best companies.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 lg:p-12 shadow-sm">
          {/* =====================================================
               TODO: Replace with real HubSpot Candidate Form values
               Portal ID: CANDIDATE_PORTAL_ID
               Form ID:   CANDIDATE_FORM_ID
               ===================================================== */}
          <div id="hubspot-candidate-form"></div>
          <noscript><p class="text-center text-gray">Please enable JavaScript to load the contact form, or email us directly.</p></noscript>
        </div>
      </div>
    </section>

    <!-- ==================== FOOTER ==================== -->
    <footer class="bg-navy-dark py-12">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="flex items-center gap-3">
            <span class="text-lg font-bold">
              <span class="text-white">The</span><span class="text-sky">Colab</span>
            </span>
            <span class="text-gray text-sm font-medium uppercase tracking-widest">Talent</span>
          </div>
          <div class="flex items-center gap-6 text-sm text-gray">
            <span>talent.thecolab.ai</span>
            <a href="https://thecolab.ai" class="hover:text-white transition-colors">thecolab.ai</a>
            <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-white/10 text-center">
          <p class="text-sm text-gray">&copy; 2026 TheColab. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <!-- HubSpot Forms -->
    <script is:inline src="//js.hsforms.net/forms/embed/v2.js" charset="utf-8"></script>
    <script is:inline>
      // =====================================================
      // TODO: Replace EMPLOYER_PORTAL_ID and EMPLOYER_FORM_ID
      //       with real HubSpot values
      // =====================================================
      if (typeof hbspt !== 'undefined') {
        hbspt.forms.create({
          region: "na1",
          portalId: "EMPLOYER_PORTAL_ID",
          formId: "EMPLOYER_FORM_ID",
          target: "#hubspot-employer-form"
        });
      }

      // =====================================================
      // TODO: Replace CANDIDATE_PORTAL_ID and CANDIDATE_FORM_ID
      //       with real HubSpot values
      // =====================================================
      if (typeof hbspt !== 'undefined') {
        hbspt.forms.create({
          region: "na1",
          portalId: "CANDIDATE_PORTAL_ID",
          formId: "CANDIDATE_FORM_ID",
          target: "#hubspot-candidate-form"
        });
      }
    </script>

  </body>
</html>
