---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Colab Talent — AI Talent. Verified and Matched. We match skills-verified AI professionals with precisely defined roles. Built by NZ's largest AI practitioner community." />
    <meta property="og:title" content="Colab Talent — AI Talent. Verified and Matched." />
    <meta property="og:description" content="We match skills-verified AI professionals with precisely defined roles, so the right people find the right opportunities, faster." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://talent.thecolab.ai" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>Colab Talent — AI Talent. Verified and Matched.</title>
  </head>
  <body class="bg-white antialiased">

    <!-- ==================== HERO ==================== -->
    <section class="relative min-h-screen flex items-center overflow-hidden bg-gradient-to-br from-navy-dark via-navy to-dark">
      <!-- Animated SVG network nodes -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <svg class="absolute right-0 top-0 w-[700px] h-[700px] opacity-20" viewBox="0 0 700 700" fill="none">
          <circle class="node-float-1" cx="350" cy="150" r="6" fill="#0EA5E9" />
          <circle class="node-float-2" cx="500" cy="250" r="4" fill="#0EA5E9" />
          <circle class="node-float-3" cx="250" cy="350" r="5" fill="#0EA5E9" />
          <circle class="node-float-1" cx="450" cy="400" r="7" fill="#38bdf8" />
          <circle class="node-float-2" cx="550" cy="150" r="3" fill="#38bdf8" />
          <circle class="node-float-3" cx="300" cy="500" r="5" fill="#0EA5E9" />
          <circle class="node-float-1" cx="600" cy="350" r="4" fill="#38bdf8" />
          <circle class="node-float-2" cx="400" cy="550" r="6" fill="#0EA5E9" />
          <circle class="node-float-3" cx="150" cy="200" r="3" fill="#38bdf8" />
          <circle class="node-float-1" cx="200" cy="450" r="4" fill="#0EA5E9" />
          <line class="node-pulse" x1="350" y1="150" x2="500" y2="250" stroke="#0EA5E9" stroke-width="1" />
          <line class="node-pulse" x1="500" y1="250" x2="450" y2="400" stroke="#0EA5E9" stroke-width="1" />
          <line class="node-pulse" x1="250" y1="350" x2="450" y2="400" stroke="#38bdf8" stroke-width="1" />
          <line class="node-pulse" x1="350" y1="150" x2="550" y2="150" stroke="#38bdf8" stroke-width="0.5" />
          <line class="node-pulse" x1="450" y1="400" x2="600" y2="350" stroke="#0EA5E9" stroke-width="0.5" />
          <line class="node-pulse" x1="300" y1="500" x2="400" y2="550" stroke="#38bdf8" stroke-width="1" />
          <line class="node-pulse" x1="250" y1="350" x2="300" y2="500" stroke="#0EA5E9" stroke-width="0.5" />
          <line class="node-pulse" x1="150" y1="200" x2="250" y2="350" stroke="#38bdf8" stroke-width="0.5" />
          <line class="node-pulse" x1="200" y1="450" x2="300" y2="500" stroke="#0EA5E9" stroke-width="1" />
          <line class="node-pulse" x1="550" y1="150" x2="600" y2="350" stroke="#0EA5E9" stroke-width="0.5" />
          <circle class="node-float-2" cx="350" cy="150" r="20" fill="#0EA5E9" opacity="0.08" />
          <circle class="node-float-1" cx="450" cy="400" r="25" fill="#0EA5E9" opacity="0.06" />
          <circle class="node-float-3" cx="300" cy="500" r="18" fill="#38bdf8" opacity="0.07" />
        </svg>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 py-24 lg:py-32">
        <!-- Logo -->
        <div class="mb-12 flex items-center">
          <img src="data:image/png;base64," alt="TheColab" style="height: 36px;" />
          <span class="text-gray ml-3 text-sm font-medium uppercase tracking-widest">Talent</span>
        </div>

        <div class="max-w-3xl">
          <h1 class="text-5xl md:text-7xl font-black text-white leading-tight mb-6">
            AI Talent.<br />
            <span class="text-sky">Verified and Matched.</span>
          </h1>
          <p class="text-xl md:text-2xl text-gray-300 leading-relaxed mb-10 max-w-2xl">
            We match skills-verified AI professionals with precisely defined roles, so the right people find the right opportunities, faster. Built by NZ&#39;s largest AI practitioner community.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#employers" class="inline-flex items-center justify-center px-8 py-4 bg-sky text-white font-semibold rounded-lg text-lg hover:bg-sky-light transition-colors duration-200 shadow-lg shadow-sky/25">
              Find AI Talent
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </a>
            <a href="#candidates" class="inline-flex items-center justify-center px-8 py-4 bg-white/10 text-white font-semibold rounded-lg text-lg hover:bg-white/20 transition-colors duration-200 border border-white/20">
              Register as a Candidate
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Bottom gradient fade -->
      <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-dark to-transparent"></div>
    </section>

    <!-- ==================== STATS BAR ==================== -->
    <section class="bg-dark py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
          <div class="border-l-2 border-sky pl-6">
            <p class="text-4xl md:text-5xl font-black text-white mb-3">400+</p>
            <p class="text-lg text-gray-300">Community Members</p>
          </div>
          <div class="border-l-2 border-sky pl-6">
            <p class="text-4xl md:text-5xl font-black text-white mb-3">500+</p>
            <p class="text-lg text-gray-300">Meetup Registrations</p>
          </div>
          <div class="border-l-2 border-sky pl-6">
            <p class="text-4xl md:text-5xl font-black text-white mb-3">NZ #1</p>
            <p class="text-lg text-gray-300">AI Practitioner Network</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== WHAT MAKES US DIFFERENT ==================== -->
    <section class="bg-white py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">What Makes Us Different</p>
          <h2 class="text-3xl md:text-5xl font-bold text-dark">Not another recruitment agency</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <!-- Define the Role -->
          <div class="group bg-gray-light rounded-2xl p-8 lg:p-10 hover:shadow-xl transition-shadow duration-300">
            <div class="w-14 h-14 bg-sky/10 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-sky" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-3">We Define the Role</h3>
            <p class="text-gray leading-relaxed">Don&#39;t know what to ask for? Tell us the problem you&#39;re solving and we&#39;ll translate it into the skills, experience, and tools you actually need. No more AI-generated job descriptions full of irrelevant requirements.</p>
          </div>
          <!-- Verify the Talent -->
          <div class="group bg-gray-light rounded-2xl p-8 lg:p-10 hover:shadow-xl transition-shadow duration-300">
            <div class="w-14 h-14 bg-sky/10 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-sky" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-3">We Verify the Talent</h3>
            <p class="text-gray leading-relaxed">Every candidate is assessed against the specific skills your role requires. Not a 30-minute phone screen. A proper, AI-powered capability evaluation that tells you exactly what someone can do.</p>
          </div>
          <!-- Make the Match -->
          <div class="group bg-gray-light rounded-2xl p-8 lg:p-10 hover:shadow-xl transition-shadow duration-300">
            <div class="w-14 h-14 bg-sky/10 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-sky" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-3">We Make the Match</h3>
            <p class="text-gray leading-relaxed">Our matching goes beyond keywords. Someone who&#39;s built production RAG pipelines is different from someone who&#39;s watched a few tutorials. We know the difference because we&#39;ve done both.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== HOW IT WORKS — ORGANISATIONS ==================== -->
    <section class="bg-gray-light py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">How It Works</p>
          <h2 class="text-3xl md:text-5xl font-bold text-dark">For Organisations</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8 lg:gap-6">
          <div class="relative text-center">
            <div class="w-16 h-16 bg-sky text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">1</div>
            <h3 class="text-lg font-bold text-dark mb-2">Describe the problem you&#39;re solving</h3>
            <p class="text-gray text-sm leading-relaxed">Tell us in plain English. Our AI translates it into the skills, experience, and tools you actually need.</p>
          </div>
          <div class="relative text-center">
            <div class="w-16 h-16 bg-sky text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">2</div>
            <h3 class="text-lg font-bold text-dark mb-2">Review your role profile</h3>
            <p class="text-gray text-sm leading-relaxed">We generate a structured brief with the right requirements. You refine it with a few taps.</p>
          </div>
          <div class="relative text-center">
            <div class="w-16 h-16 bg-sky text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">3</div>
            <h3 class="text-lg font-bold text-dark mb-2">Get a verified shortlist</h3>
            <p class="text-gray text-sm leading-relaxed">We match and verify candidates against your specific requirements. You interview the best, not the most available.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== HOW IT WORKS — CANDIDATES ==================== -->
    <section class="bg-white py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">How It Works</p>
          <h2 class="text-3xl md:text-5xl font-bold text-dark">For Candidates</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8 lg:gap-6">
          <div class="relative text-center">
            <div class="w-16 h-16 bg-sky text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">1</div>
            <h3 class="text-lg font-bold text-dark mb-2">Build your profile</h3>
            <p class="text-gray text-sm leading-relaxed">Register in under 5 minutes. Link your LinkedIn or upload your CV. Always free.</p>
          </div>
          <div class="relative text-center">
            <div class="w-16 h-16 bg-sky text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">2</div>
            <h3 class="text-lg font-bold text-dark mb-2">Showcase your skills</h3>
            <p class="text-gray text-sm leading-relaxed">Complete AI-powered assessments that actually demonstrate what you can do.</p>
          </div>
          <div class="relative text-center">
            <div class="w-16 h-16 bg-sky text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">3</div>
            <h3 class="text-lg font-bold text-dark mb-2">Get matched</h3>
            <p class="text-gray text-sm leading-relaxed">We surface you to the right roles based on verified skills, not just keywords.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== NZ AI STATS ==================== -->
    <section class="bg-gradient-to-br from-navy-dark via-navy to-dark py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">The Opportunity</p>
          <h2 class="text-3xl md:text-5xl font-bold text-white">AI in New Zealand</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
          <div class="text-center">
            <p class="text-5xl md:text-6xl font-black text-sky mb-4">87%</p>
            <p class="text-lg text-gray-300 mb-2">of NZ organisations now use AI</p>
            <p class="text-sm text-gray">Up from 48% in 2023</p>
            <p class="text-xs text-gray mt-1 italic">AI Forum NZ, August 2025</p>
          </div>
          <div class="text-center">
            <p class="text-5xl md:text-6xl font-black text-sky mb-4">32%</p>
            <p class="text-lg text-gray-300 mb-2">cite skills as the #1 barrier</p>
            <p class="text-sm text-gray">to AI adoption</p>
            <p class="text-xs text-gray mt-1 italic">NZ AI Strategy</p>
          </div>
          <div class="text-center">
            <p class="text-5xl md:text-6xl font-black text-sky mb-4">$76B</p>
            <p class="text-lg text-gray-300 mb-2">economic potential from AI in NZ</p>
            <p class="text-sm text-gray">by 2038</p>
            <p class="text-xs text-gray mt-1 italic">NZ AI Strategy, July 2025</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== FOR EMPLOYERS + CANDIDATES ==================== -->
    <section id="employers" class="py-24 lg:py-32" style="background: linear-gradient(180deg, #ffffff 0%, #f0f9ff 100%);">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">Get Started</p>
          <h2 class="text-3xl md:text-5xl font-bold text-dark mb-4">For Employers and Candidates</h2>
          <p class="text-xl text-gray max-w-3xl mx-auto">Choose the path that fits you. Employers can brief us on the role they need to fill, and candidates can join the network in minutes.</p>
        </div>
        <div class="grid gap-8 lg:grid-cols-2">
          <div class="bg-gray-light rounded-3xl p-8 lg:p-12 border border-gray-200/70">
            <div class="mb-10">
              <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">For Employers</p>
              <h3 class="text-3xl md:text-4xl font-bold text-dark mb-4">Find AI Talent</h3>
              <p class="text-lg text-gray">Tell us the problem you&#39;re solving. We&#39;ll handle the rest.</p>
            </div>
            <form id="employer-form" class="space-y-4">
              <input type="text" name="name" placeholder="Your name" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-sky-500" />
              <input type="text" name="company" placeholder="Company name" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-sky-500" />
              <input type="email" name="email" placeholder="Work email" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-sky-500" />
              <textarea name="message" placeholder="Tell us briefly what you're looking for (optional)" rows="3" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-sky-500"></textarea>
              <button type="submit" class="w-full py-4 bg-sky-500 text-white font-semibold rounded-lg hover:bg-sky-600 transition-colors">Find AI Talent →</button>
            </form>
            <div id="employer-success" class="hidden text-center text-green-600 font-medium py-4">✓ Thanks! We&apos;ll be in touch within 48 hours.</div>
            <div id="employer-error" class="hidden text-center text-red-500 py-4">Something went wrong. Please try again.</div>
            <noscript><p class="text-center text-gray">Please enable JavaScript to submit the form, or email us directly.</p></noscript>
          </div>
          <div id="candidates" class="bg-white rounded-3xl p-8 lg:p-12 shadow-sm border border-sky/20">
            <div class="mb-10">
              <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">For Candidates</p>
              <h3 class="text-3xl md:text-4xl font-bold text-dark mb-4">Join the Colab Talent Network</h3>
              <p class="text-lg text-gray">Register in under 5 minutes. Always free.</p>
            </div>
            <form id="candidate-form" class="space-y-4">
              <input type="text" name="name" placeholder="Your name" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-sky-500" />
              <input type="email" name="email" placeholder="Email address" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-sky-500" />
              <input type="text" name="message" placeholder="Your main AI skill/area (e.g. ML engineering, data science)" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-sky-500" />
              <button type="submit" class="w-full py-4 bg-sky-500 text-white font-semibold rounded-lg hover:bg-sky-600 transition-colors">Join the Network →</button>
            </form>
            <div id="candidate-success" class="hidden text-center text-green-600 font-medium py-4">✓ You&apos;re on the list! We&apos;ll match you with opportunities as they come in.</div>
            <div id="candidate-error" class="hidden text-center text-red-500 py-4">Something went wrong. Please try again.</div>
            <noscript><p class="text-center text-gray">Please enable JavaScript to submit the form, or email us directly.</p></noscript>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== PRICING ==================== -->
    <section class="bg-white py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">Pricing</p>
          <h2 class="text-3xl md:text-5xl font-bold text-dark mb-4">Transparent placement fees. No surprises.</h2>
          <p class="text-xl text-gray max-w-3xl mx-auto">You only pay when we successfully place someone. Candidates always join for free.</p>
        </div>
        <div class="grid gap-8 lg:grid-cols-3">
          <div class="rounded-3xl border border-gray-200 bg-gray-light p-8 lg:p-10 shadow-sm">
            <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">Permanent Placement</p>
            <div class="flex items-end gap-3 mb-6">
              <span class="text-5xl font-black text-dark">10%</span>
              <span class="text-lg text-gray mb-1">of base salary</span>
            </div>
            <p class="text-gray leading-relaxed mb-8">A single success fee when your permanent hire starts. No ongoing costs, no hidden charges.</p>
            <ul class="space-y-4 mb-10 text-gray">
              <li class="flex items-start gap-3"><span class="text-sky font-bold">•</span><span>Skills-verified candidates</span></li>
              <li class="flex items-start gap-3"><span class="text-sky font-bold">•</span><span>AI-matched shortlist</span></li>
              <li class="flex items-start gap-3"><span class="text-sky font-bold">•</span><span>Pay on successful placement</span></li>
              <li class="flex items-start gap-3"><span class="text-sky font-bold">•</span><span>Full candidate tracking</span></li>
            </ul>
            <a href="#employers" class="inline-flex items-center justify-center w-full px-6 py-4 bg-sky text-white font-semibold rounded-lg hover:bg-sky-light transition-colors">Start Hiring →</a>
          </div>
          <div class="rounded-3xl border border-sky/30 bg-gradient-to-br from-navy/5 to-white p-8 lg:p-10 shadow-sm">
            <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">Contract Placement</p>
            <div class="flex items-end gap-3 mb-6">
              <span class="text-5xl font-black text-dark">20%</span>
              <span class="text-lg text-gray mb-1">of hourly rate</span>
            </div>
            <p class="text-gray leading-relaxed mb-8">A simple margin on the contractor's hourly rate. Billed as they work, no upfront commitment.</p>
            <ul class="space-y-4 mb-10 text-gray">
              <li class="flex items-start gap-3"><span class="text-sky font-bold">•</span><span>Flexible contract terms</span></li>
              <li class="flex items-start gap-3"><span class="text-sky font-bold">•</span><span>Verified AI contractors</span></li>
              <li class="flex items-start gap-3"><span class="text-sky font-bold">•</span><span>Scale up or down easily</span></li>
              <li class="flex items-start gap-3"><span class="text-sky font-bold">•</span><span>Payroll handled for you</span></li>
            </ul>
            <a href="#employers" class="inline-flex items-center justify-center w-full px-6 py-4 bg-dark text-white font-semibold rounded-lg hover:bg-navy transition-colors">Find Contractors →</a>
          </div>
          <div class="rounded-3xl border border-sky/30 bg-gradient-to-br from-sky-50 to-white p-8 lg:p-10 shadow-sm">
            <p class="text-sky font-semibold uppercase tracking-widest text-sm mb-4">Candidates</p>
            <div class="flex items-end gap-3 mb-6">
              <span class="text-5xl font-black text-dark">Free</span>
              <span class="text-lg text-gray mb-1">forever</span>
            </div>
            <p class="text-gray leading-relaxed mb-8">Create a profile, get verified, and let employers come to you. Always free for AI professionals.</p>
            <ul class="space-y-4 mb-10 text-gray">
              <li class="flex items-start gap-3"><span class="text-sky font-bold">•</span><span>Create profile</span></li>
              <li class="flex items-start gap-3"><span class="text-sky font-bold">•</span><span>Apply to jobs</span></li>
